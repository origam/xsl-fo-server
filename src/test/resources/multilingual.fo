<fo:root xmlns:fo="http://www.w3.org/1999/XSL/Format">
  <fo:layout-master-set>
    <fo:simple-page-master master-name="A4" page-height="29.7cm" page-width="21cm" margin="2cm">
      <fo:region-body/>
    </fo:simple-page-master>
  </fo:layout-master-set>
  <fo:page-sequence master-reference="A4">
    <fo:flow flow-name="xsl-region-body">
      <fo:block font-family="Noto Sans" font-size="12pt">Žluťoučký kůň pěl ďábelské ódy.</fo:block>
      <fo:block font-family="Noto Sans" font-size="12pt">Καλημέρα κόσμε.</fo:block>
      <fo:block font-family="Noto Sans" font-size="12pt">Привет мир.</fo:block>
      <fo:block font-family="Noto Sans Hebrew" font-size="12pt">שלום עולם</fo:block>
      <fo:block font-family="Noto Sans Arabic" font-size="12pt">مرحبا بالعالم</fo:block>
      <fo:block font-family="Noto Sans Devanagari" font-size="12pt">नमस्ते दुनिया</fo:block>
    </fo:flow>
  </fo:page-sequence>
</fo:root>
